# --- Solana / pump.fun ---
# The mint address of the token to watch
TOKEN_MINT_ADDRESS=YOUR_MINT_ADDRESS_HERE
# Required for subscribeTokenTrade/subscribeAccountTrade. Get this from
# pumpportal.fun's Trading API dashboard; the associated wallet must hold
# at least 0.02 SOL or the subscription is rejected (see README).
PUMPPORTAL_API_KEY=YOUR_PUMPPORTAL_API_KEY_HERE

# --- Telegram ---
# Get this from @BotFather (see README)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
# The group chat id to post alerts to (see README for how to find it)
TELEGRAM_CHAT_ID=YOUR_GROUP_CHAT_ID_HERE

# --- Branding (optional) ---
# Shown in the tweet-intent text as "X SOL BUY on $TICKER!". Leave blank to omit.
TOKEN_TICKER=

# --- Alert behavior ---
# Minimum SOL amount for a buy to trigger an alert.
# Use a small value like 0.05 for testing, then raise it for production.
BUY_THRESHOLD_SOL=5

# --- Local wiring ---
# Port the Express backend listens on
PORT=3000
# URL the listener posts qualifying buys to (must match PORT above)
BACKEND_URL=http://localhost:3000/trigger-burn

# --- ffmpeg (optional) ---
# Path to a .ttf font file for the text overlay. If left blank, the app will
# try a few common OS default locations (see README).
FONT_PATH=

# --- Debugging (optional) ---
# Set to true to log every raw event pump.fun sends (including rejection/
# error messages) - useful when you're not seeing expected buy logs.
DEBUG=false
